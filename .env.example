# EvolveAI Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# RevenueCat (for in-app purchases)
EXPO_PUBLIC_REVENUECAT_IOS=your-revenuecat-ios-key
EXPO_PUBLIC_REVENUECAT_ANDROID=your-revenuecat-android-key

# OpenAI (set this as a Supabase Edge Function secret, NOT in the app)
# Run: supabase secrets set OPENAI_API_KEY=sk-your-key-here
# OPENAI_API_KEY=sk-your-key-here
