{
  "name": "massmash-ai",
  "version": "1.0.0",
  "description": "MassMash AI Desktop Client - KI-Chat mit LLM-Backend, Gaming Optimizer, Hardware Advisor",
  "main": "main.js",
  "author": "MassMash Team",
  "license": "MIT",
  "homepage": "https://github.com/songoku1callme-dev/MassMash",
  "repository": {
    "type": "git",
    "url": "https://github.com/songoku1callme-dev/MassMash.git"
  },
  "scripts": {
    "start": "electron .",
    "start:dev": "electron . --dev",
    "prebuild": "cd ../frontend && npm run build",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --win --mac --linux",
    "package:win": "electron-builder --win --dir",
    "package:mac": "electron-builder --mac --dir",
    "package:linux": "electron-builder --linux --dir",
    "publish": "electron-builder --win --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.massmash.ai",
    "productName": "MassMash AI",
    "artifactName": "MassMash-AI-Setup-${version}.${ext}",
    "copyright": "Copyright (c) 2026 MassMash Team",
    "directories": {
      "output": "dist",
      "buildResources": "."
    },
    "files": [
      "main.js",
      "preload.js",
      "splash.html",
      "icon.png",
      "icon.ico"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!__pycache__/**",
          "!.pytest_cache/**",
          "!tests/**",
          "!.env",
          "!*.pyc"
        ]
      },
      {
        "from": "../frontend/dist",
        "to": "frontend/dist"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.ico",
      "publisherName": "MassMash Team"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MassMash AI",
      "license": "../LICENSE"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "icon.png",
      "category": "public.app-category.productivity"
    },
    "dmg": {
      "title": "MassMash AI ${version}",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.png",
      "category": "Utility",
      "desktop": {
        "StartupWMClass": "massmash-ai"
      }
    },
    "publish": {
      "provider": "github",
      "owner": "songoku1callme-dev",
      "repo": "MassMash",
      "releaseType": "release"
    }
  }
}
