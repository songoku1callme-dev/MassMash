{
  "name": "massmash-ai",
  "version": "1.0.0",
  "description": "MassMash AI Desktop Client - KI-Chat mit LLM-Backend",
  "main": "main.js",
  "author": "MassMash",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "start:dev": "electron . --dev",
    "package:win": "electron-builder --win",
    "package:mac": "electron-builder --mac",
    "package:linux": "electron-builder --linux"
  },
  "dependencies": {
    "electron": "^28.0.0"
  },
  "devDependencies": {
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.massmash.ai",
    "productName": "MassMash AI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "icon.png"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend/dist"
      }
    ],
    "win": {
      "target": ["nsis"],
      "icon": "icon.png"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "icon.png"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "icon.png"
    }
  }
}
