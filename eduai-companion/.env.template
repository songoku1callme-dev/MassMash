# ============================================================
# EduAI Companion — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in the values.
#   cp .env.template .env
# ============================================================

# --- REQUIRED ---

# JWT signing key (generate one with):
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# Groq LLM API key — https://console.groq.com/keys
# Without this key the app falls back to the built-in template engine.
GROQ_API_KEY=

# --- OPTIONAL (production) ---

# Set to "1" to enable permissive CORS (allow all origins).
# Leave empty or unset in production.
# EDUAI_DEV_MODE=1

# SQLite database path (default: app.db in working dir).
# On Fly.io with a mounted volume use /data/app.db.
# DATABASE_PATH=/data/app.db

# --- FUTURE (scaffolded, not yet active) ---

# Clerk OAuth — https://dashboard.clerk.com
# CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# PostHog Analytics (anonymous, GDPR-compliant) — https://posthog.com
# POSTHOG_API_KEY=
# POSTHOG_HOST=https://eu.posthog.com

# Sentry Error Monitoring — https://sentry.io
# SENTRY_DSN=

# Redis (for distributed rate limiting) — e.g. Fly.io Redis add-on
# REDIS_URL=

# PostgreSQL (when migrating from SQLite)
# DATABASE_URL=postgresql://user:password@host:5432/eduai
