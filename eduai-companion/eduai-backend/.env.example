# ============================================================
# Lumnos Backend — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env with real secrets!
# ============================================================

# --- Core ---
SECRET_KEY=change-me-random-64-characters
DATABASE_PATH=lumnos.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/lumnos

# --- Authentication (Clerk) ---
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...

# --- AI / LLM ---
GROQ_API_KEY=gsk_...

# --- Payments (Stripe) ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Internet Research (Tavily) ---
TAVILY_API_KEY=tvly-...

# --- Email (Resend) ---
RESEND_API_KEY=re_...

# --- Fly.io Deployment ---
# Set via `flyctl secrets set` — not needed in .env
# FLY_API_TOKEN=...

# --- Feature Flags ---
LUMNOS_DEV_MODE=1
