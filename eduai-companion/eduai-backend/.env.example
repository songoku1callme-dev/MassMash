# === LUMNOS Backend Environment Variables ===
# Copy this file to .env and fill in your values.
# NEVER commit .env with real keys!

# Groq LLM
GROQ_API_KEY=gsk_YOUR_GROQ_KEY_HERE

# Clerk OAuth
CLERK_SECRET_KEY=sk_test_YOUR_CLERK_SECRET_HERE
CLERK_PUBLISHABLE_KEY=pk_test_YOUR_CLERK_PUBLISHABLE_HERE

# Tavily (Internet-Recherche)
TAVILY_API_KEY=tvly-YOUR_TAVILY_KEY_HERE

# Resend (E-Mail Service)
RESEND_API_KEY=re_YOUR_RESEND_KEY_HERE

# Stripe (USE TEST KEYS IN DEVELOPMENT!)
# WARNING: Never use sk_live_ keys in development!
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_HERE
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_HERE
STRIPE_WEBHOOK_SECRET_1=whsec_YOUR_WEBHOOK_SECRET_1
STRIPE_WEBHOOK_SECRET_2=whsec_YOUR_WEBHOOK_SECRET_2

# PostHog Analytics
POSTHOG_API_KEY=phc_YOUR_POSTHOG_KEY_HERE

# Sentry Error Tracking
SENTRY_DSN=https://YOUR_SENTRY_DSN_HERE

# JWT Signing (generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
SECRET_KEY=CHANGE_ME_GENERATE_A_SECURE_KEY

# Dev Mode (set to 0 in production!)
LUMNOS_DEV_MODE=0
