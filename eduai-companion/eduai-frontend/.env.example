# ============================================================
# Lumnos Frontend — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# For Vercel: set these in the Vercel Dashboard > Settings > Environment Variables
# ============================================================

# --- Backend API URL ---
# Local development:
VITE_API_URL=http://localhost:8000
# Production (Fly.io):
# VITE_API_URL=https://lumnos-backend.fly.dev

# --- Authentication (Clerk) ---
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# --- Owner Emails (comma-separated) ---
# These emails get full owner rights: Admin-Panel, green star, no upgrade CTAs
VITE_OWNER_EMAILS=owner1@example.com,owner2@example.com
